{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              [":NODE:", ":BUN:"],
              [
                ":PACKAGE:",
                "!@domain",
                "!@domain/**",
                "!@infraestructure",
                "!@infraestructure/**",
                "!@features",
                "!@features/**",
                "!@templates",
                "!@templates/**",
                "!@theme",
                "!@theme/**"
              ],
              [
                "@domain",
                "@domain/**",
                "@infraestructure",
                "@infraestructure/**",
                "@features",
                "@features/**",
                "@templates",
                "@templates/**",
                "@theme",
                "@theme/**"
              ],
              [":PATH:"]
            ]
          }
        }
      }
    }
  }
}
