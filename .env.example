# Copy to `.env` (gitignored) and fill in. Loaded at startup by the backend.
#
# Argon2id hash of the owner password — seeded as the owner account on first
# boot. Generate with: cargo run -- hash-password
# (or, from a built image: docker run --rm -it IMAGE hash-password)
# Single-quote the value so the '$' segments aren't treated as variables.
VAULT_OWNER_PASSWORD_HASH='$argon2id$v=19$m=19456,t=2,p=1$REPLACE_WITH_YOUR_HASH'
